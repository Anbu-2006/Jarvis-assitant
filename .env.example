# =============================================================================
# JARVIS — Environment Configuration
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Providers — Multi-LLM Cascade (at least ONE is required)
# ---------------------------------------------------------------------------

# LOCAL: Ollama (100% private, no API key needed)
# Run `ollama run llama3.2:3b` or `ollama run phi3` in terminal first
# Uncomment this to force local AI as the primary engine.
OLLAMA_MODEL=llama3.2:3b

# PRIMARY CLOUD: DeepSeek V4 Flash via NVIDIA NIM
# Get your free key at: https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here

# SECONDARY: Groq (ultra-fast inference — Llama 3.3, Whisper STT, Orpheus TTS)
# Get your free key at: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_key_here
# Optional rotation keys for higher quotas:
# GROQ_API_KEY_2=gsk_optional_key_2
# GROQ_API_KEY_3=gsk_optional_key_3

# TERTIARY: Google Gemini 3 Flash (conversational fallback)
# Get your free key at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# QUATERNARY: OpenRouter (last resort — free models)
# Get your free key at: https://openrouter.ai/
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# ---------------------------------------------------------------------------
# Personalization
# ---------------------------------------------------------------------------

# Your name (JARVIS will address you by name)
# USER_NAME=Tony

# How JARVIS addresses you (defaults to "sir")
# HONORIFIC=sir

# ---------------------------------------------------------------------------
# TTS — Edge-TTS is used by default (free, no API key needed)
# Optional: Sarvam TTS for Indian English context
# ---------------------------------------------------------------------------
# SARVAM_API_KEY=your_sarvam_key
