# =============================================================================
# JARVIS — Environment Configuration
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Provider (required) — DeepSeek V4 Flash via NVIDIA NIM
# ---------------------------------------------------------------------------

# NVIDIA NIM (DeepSeek V4 Flash) — https://build.nvidia.com
NVIDIA_API_KEY=your-nvidia-api-key-here

# ---------------------------------------------------------------------------
# TTS — handled locally via Edge-TTS (free, no API key needed)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Personalization
# ---------------------------------------------------------------------------

# Your name (JARVIS will address you by name)
# USER_NAME=Tony

# How JARVIS addresses you (defaults to "sir")
# HONORIFIC=sir
